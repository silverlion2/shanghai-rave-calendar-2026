{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/shanghai-rave-calendar-2026.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/poster-archive",
      "destination": "/poster-wall",
      "permanent": true
    },
    {
      "source": "/poster-archive.html",
      "destination": "/poster-wall",
      "permanent": true
    },
    {
      "source": "/events",
      "destination": "/poster-wall",
      "permanent": true
    },
    {
      "source": "/events/index.html",
      "destination": "/poster-wall",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=2592000"
        }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
