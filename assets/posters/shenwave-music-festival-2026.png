<main>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div class="hero__copy">
        <div class="hero__row">
          <span>Registered in Ontario · based in Mississauga</span>
          <span class="sep"></span>
          <span>Technology studio</span>
        </div>

        <h1 class="h-display">
          A Mississauga technology studio building private products, AI-assisted workflows, and selected web projects.
        </h1>

        <p class="hero__lead lead">
          Shenwave supports ongoing product work, internal experiments, and focused client projects where small, practical technology work can move something forward.
        </p>

        <div class="hero__actions">
          <a href="/projects.html" class="btn btn--ink">View active work</a>
          <a href="/about.html" class="btn btn--light">Company details</a>
        </div>

        <div class="hero__proof" aria-label="Common engagement formats">
          <div><strong>Ontario</strong><span>Registered trade name</span></div>
          <div><strong>Active</strong><span>Product and client work</span></div>
          <div><strong>Selective</strong><span>Web, AI, and prototype projects</span></div>
        </div>
      </div>

      <aside class="hero-panel" aria-label="Studio activity summary">
        <div class="hero-panel__top">
          <span>Studio activity</span>
          <strong>Active technology work</strong>
        </div>
        <div class="delivery-map">
          <div class="delivery-step is-active">
            <span>01</span>
            <div>
              <h3>Private AI platform work</h3>
              <p>Ongoing product and technical work for a private AI platform.</p>
            </div>
          </div>
          <div class="delivery-step">
            <span>02</span>
            <div>
              <h3>Private iOS product experiment</h3>
              <p>An early-stage mobile product exploring personal moments and lightweight organization.</p>
            </div>
          </div>
          <div class="delivery-step">
            <span>03</span>
            <div>
              <h3>Client and web projects</h3>
              <p>Selected website, AI workflow, and prototype work for clients and internal experiments.</p>
            </div>
          </div>
        </div>
        <div class="hero-panel__footer">
          <span>Based in</span>
          <strong>Mississauga, Ontario</strong>
        </div>
      </aside>
    </div>
  </div>
</section>

<!-- STUDIO STATUS -->
<section class="section section--tight offers-section" id="offers">
  <div class="container">
    <div class="section-head">
      <h2 class="h-2">A real operating studio, with room for selected client work.</h2>
      <p>The site is built to make Shenwave easy to verify while still making it clear what kind of technology work we can take on.</p>
    </div>
  </div>

  <div class="services">
    <article class="service">
      <span class="service__num">01 / Company record</span>
      <h3 class="service__title">Registered Ontario business.</h3>
      <p class="service__desc">Shenwave is a registered trade name of 1001262597 Ontario Inc., based in Mississauga and operating as a technology studio.</p>
      <ul class="service__list">
        <li>Legal entity <span class="badge">Ontario Inc.</span></li>
        <li>Registered name <span class="badge">Shenwave</span></li>
        <li>Founder <span class="badge">Yichen Shen</span></li>
      </ul>
      <a class="service__link" href="/about.html">See company details</a>
    </article>

    <article class="service">
      <span class="service__num">02 / Active work</span>
      <h3 class="service__title">Product, platform, and web work.</h3>
      <p class="service__desc">The studio supports private AI platform work, an early iOS product experiment, client website work, and internal AI workflow experiments.</p>
      <ul class="service__list">
        <li>Private AI platform <span class="badge">ongoing</span></li>
        <li>Private iOS product <span class="badge">in dev</span></li>
        <li>Client website project <span class="badge">active</span></li>
      </ul>
      <a class="service__link" href="/projects.html">View projects</a>
    </article>

    <article class="service">
      <span class="service__num">03 / Selected services</span>
      <h3 class="service__title">Available for focused technology projects.</h3>
      <p class="service__desc">Shenwave can help with AI workflow support, website and launch page builds, and early product prototype support when the scope is clear.</p>
      <ul class="service__list">
        <li>AI workflow support <span class="badge">selected</span></li>
        <li>Website builds <span class="badge">selected</span></li>
        <li>Prototype support <span class="badge">selected</span></li>
      </ul>
      <a class="service__link" href="/services.html">See services</a>
    </article>
  </div>
</section>

<!-- DELIVERY -->
<section class="section delivery-section">
  <div class="container">
    <div class="delivery-grid">
      <div>
        <p class="eyebrow"><span class="dot"></span>Operating model</p>
        <h2 class="h-2" style="margin-top: 24px;">Built for credibility first, leads second.</h2>
        <p class="lead" style="margin-top: 24px;">
          Shenwave is not positioned as a broad outsourcing shop. It is a small studio with active commercial and product work, open to focused projects that fit.
        </p>
      </div>
      <div class="outcome-board">
        <div class="outcome-row">
          <span>Verify</span>
          <p>Company identity, legal entity, founder, location, and contact information are easy to find.</p>
        </div>
        <div class="outcome-row">
          <span>Operate</span>
          <p>Active technology work is described without exposing private clients, contracts, or unreleased products.</p>
        </div>
        <div class="outcome-row">
          <span>Lead</span>
          <p>Potential clients can still understand where Shenwave can help: AI workflows, websites, and prototypes.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-band">
